# CaseCraft Configuration

# --------------------------
# General Settings
# --------------------------
general:
  # The Ollama model to use for generation and condensation.
  # Options:
  # - "llama3.1:8b" (Balanced)
  # - "gemma3:12b" (Best structured output)
  # - "llama3.2:3b" (Fastest Local)
  model: "llama3.1:8b"

  # Backend provider:
  #   "ollama"  — Local Ollama server (default)
  #   "openai"  — OpenAI / Azure OpenAI / vLLM / LocalAI
  #   "google"  — Google Gemini
  #   "copilot" — GitHub Models API (requires GITHUB_TOKEN with models:read scope)
  llm_provider: "ollama"
  
  # API Endpoint
  # - Ollama: http://localhost:11434
  # - OpenAI/vLLM/LocalAI: http://localhost:8000/v1
  # - Google: https://generativelanguage.googleapis.com/v1beta
  # - Copilot: https://models.github.ai/inference
  base_url: "http://localhost:11434"
  
  # API Key — NEVER put real keys here. Use env var CASECRAFT_GENERAL_API_KEY instead.
  # - Ollama: "ollama" (no real key needed)
  # - Copilot: use env var CASECRAFT_GENERAL_API_KEY with your GITHUB_TOKEN
  api_key: "ollama"  # Default for local Ollama (no real key needed)

  # Context window ratio (0.0-1.0). Fraction of model's native window to use.
  # Auto-detected for Ollama; other providers default to 128K.
  # 0.75 = use 75%. Lower values reduce RAM. 1.0 = full window.
  context_window_ratio: 0.75

  # Minimum guaranteed output tokens.
  # Output allocation is dynamic: remaining context after input tokens
  # goes to output, but never below this floor. Per-model caps are enforced
  # automatically (see MODEL_SPECS in core/llm_client.py).
  min_output_tokens: 1024

  # Maximum number of retries if the LLM generates invalid JSON.
  max_retries: 2

  # Minimum seconds between consecutive LLM API calls.
  # Prevents rate-limit (429) errors on providers with strict RPM caps.
  # GitHub Models free tier: set to 6-8 (10 RPM cap).
  # Ollama / local: 0 (no delay needed).
  llm_call_delay: 0

# --------------------------
# Generation Parameters
# --------------------------
generation:
  # Size of document chunks (in characters).
  # Larger chunks = more context but potentially lost details.
  # Smaller chunks = more focus but potentially missed cross-references.
  chunk_size: 800
  
  # Overlap between chunks to maintain continuity.
  chunk_overlap: 100
  
  # Creativity of the model (0.0 - 1.0).
  # Lower values (0.1-0.2) are better for structured JSON output.
  temperature: 0.2
  
  # The type of application being tested (web, mobile, desktop, api).
  # This configures the specific types of test cases generated.
  app_type: "web"

  # Minimum test cases per chunk. Triggers re-generation if under this count.
  # Set to 0 to disable re-generation (recommended for local CPU models).
  min_cases_per_chunk: 5

  # Maximum test cases to generate per chunk.
  # 0 = unlimited (model decides). 3-5 recommended for local CPU models.
  max_cases_per_chunk: 0

  # Maximum parallel threads for chunk generation.
  # Set to 1 for rate-limited providers (copilot, openai) to avoid
  # concurrent API calls that exhaust the RPM quota instantly.
  # 4 = good for local Ollama / unlimited APIs.
  max_workers: 4

# --------------------------
# Output Settings
# --------------------------
output:
  # Default output format: 'excel' or 'json'.
  default_format: "excel"
  
  # Directory where outputs are saved by default.
  output_dir: "outputs"

# --------------------------
# Quality & Performance
# --------------------------
quality:
  # Enable semantic deduplication (removes similar test cases).
  # Uses local embeddings (fast).
  semantic_deduplication: true
  
  # Threshold for similarity (0.0 - 1.0).
  # Higher = stricter (test cases must be nearly identical to remove).
  similarity_threshold: 0.85
  
  # Enable the Reviewer Pass (slow).
  # If true, an extra LLM call validates and polishes the test suite.
  reviewer_pass: true

# --------------------------
# Knowledge Base Settings
# --------------------------
knowledge:
  # ChromaDB persistence directory for the vector store.
  # Data is stored on disk — no reload on restart.
  vector_db_path: "knowledge_base/chroma_db"

  kb_chunk_size: 1500
  min_score_threshold: 0.1

  # Query Transforms
  query_decomposition: true   # Decompose into focused sub-queries
  query_expansion: true        # Add domain synonyms for recall
  max_sub_queries: 4           # Max sub-queries per retrieval

  # Parent-Child Chunking
  parent_child_chunking: false # Two-tier chunking: small children for search, parents for context
  child_chunk_size: 400        # Max chars per child chunk
  child_overlap: 50            # Overlap between adjacent children

  # Knowledge Graph
  knowledge_graph: false       # Build relation graph over chunks at ingest time
  graph_path: "knowledge_base/knowledge_graph.json"
  graph_max_hops: 2            # BFS hops for retrieval expansion
  graph_max_expansion: 3       # Max graph-expanded chunks per query

# --------------------------
# Cache & Indexing
# --------------------------
cache:
  enable_condensation_cache: true   # Cache LLM condensation by content hash
  enable_retrieval_cache: true      # Cache RAG retrieval by query hash
  enable_prompt_cache: true         # Cache rendered prompt templates
  condensation_cache_size: 256      # Max LRU entries for condensation
  retrieval_cache_size: 64          # Max LRU entries for retrieval
  retrieval_cache_ttl: 300.0        # Retrieval cache TTL (seconds, 0 = no expiry)
  prompt_cache_size: 32             # Max LRU entries for prompts
  persist_bm25_index: true          # Persist BM25 index to disk
